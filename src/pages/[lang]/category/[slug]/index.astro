---
import Layout from "@/layouts/main.astro"
import PageHeader from "@/components/layout/PageHeader.astro"
import PageSection from "@/components/layout/PageSection.astro"
import PostCardGrid from "@/components/lists/PostCardGrid.astro"
import Pagination from "@/components/navigation/Pagination.astro"
import { LOCALES, type Locale } from "@/config/locales"
import { TAXONOMY_POSTS_PER_PAGE } from "@/config/pagination"
import { TAXONOMY, getCategory } from "@/config/taxonomy"
import { getPaginationLinks, getTotalPages } from "@/utils/pagination"
import { getPostsByCategory } from "@/utils/posts"

export async function getStaticPaths() {
  const paths = []

  for (const lang of LOCALES) {
    for (const category of TAXONOMY.categories) {
      const posts = await getPostsByCategory(lang, category.slug)
      if (posts.length > 0) {
        paths.push({
          params: { lang, slug: category.slug },
          props: { lang, slug: category.slug },
        })
      }
    }
  }

  return paths
}

const { lang, slug } = Astro.props as { lang: Locale; slug: string }
const category = getCategory(slug)
const posts = await getPostsByCategory(lang, slug)
const pagePosts = posts.slice(0, TAXONOMY_POSTS_PER_PAGE)
const totalPages = getTotalPages(posts.length, TAXONOMY_POSTS_PER_PAGE)
const pagination = getPaginationLinks({
  currentPage: 1,
  totalPages,
  buildPageUrl: (page) =>
    page === 1
      ? `/${lang}/category/${slug}/`
      : `/${lang}/category/${slug}/${page}/`,
})
---

<Layout
  lang={lang}
  path={`/category/${slug}/`}
  title={category?.labelByLocale[lang] ?? slug}
  description={category?.descriptionByLocale[lang]}
>
  <PageSection>
    <PageHeader
      title={category?.labelByLocale[lang] ?? slug}
      subtitle={category?.descriptionByLocale[lang]}
    />
    <PostCardGrid posts={pagePosts} />
    {
      totalPages > 1 && (
        <Pagination
          next={pagination.next}
          last={pagination.last}
          currentPage={1}
          totalPages={totalPages}
        />
      )
    }
  </PageSection>
</Layout>
