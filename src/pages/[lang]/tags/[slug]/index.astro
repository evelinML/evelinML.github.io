---
import Layout from "@/layouts/main.astro"
import PageHeader from "@/components/layout/PageHeader.astro"
import PageSection from "@/components/layout/PageSection.astro"
import PostCardGrid from "@/components/lists/PostCardGrid.astro"
import Pagination from "@/components/navigation/Pagination.astro"
import { LOCALES, type Locale } from "@/config/locales"
import { TAXONOMY_POSTS_PER_PAGE } from "@/config/pagination"
import { TAXONOMY, getTag } from "@/config/taxonomy"
import { getPaginationLinks, getTotalPages } from "@/utils/pagination"
import { getPostsByTag } from "@/utils/posts"

export async function getStaticPaths() {
  const paths = []

  for (const lang of LOCALES) {
    for (const tag of TAXONOMY.tags) {
      const posts = await getPostsByTag(lang, tag.slug)
      if (posts.length > 0) {
        paths.push({
          params: { lang, slug: tag.slug },
          props: { lang, slug: tag.slug },
        })
      }
    }
  }

  return paths
}

const { lang, slug } = Astro.props as { lang: Locale; slug: string }
const tag = getTag(slug)
const posts = await getPostsByTag(lang, slug)
const pagePosts = posts.slice(0, TAXONOMY_POSTS_PER_PAGE)
const totalPages = getTotalPages(posts.length, TAXONOMY_POSTS_PER_PAGE)
const pagination = getPaginationLinks({
  currentPage: 1,
  totalPages,
  buildPageUrl: (page) =>
    page === 1 ? `/${lang}/tags/${slug}/` : `/${lang}/tags/${slug}/${page}/`,
})
---

<Layout
  lang={lang}
  path={`/tags/${slug}/`}
  title={tag?.labelByLocale[lang] ?? slug}
  description={tag?.descriptionByLocale[lang]}
>
  <PageSection>
    <PageHeader
      title={tag?.labelByLocale[lang] ?? slug}
      subtitle={tag?.descriptionByLocale[lang]}
    />
    <PostCardGrid posts={pagePosts} />
    {
      totalPages > 1 && (
        <Pagination
          next={pagination.next}
          last={pagination.last}
          currentPage={1}
          totalPages={totalPages}
        />
      )
    }
  </PageSection>
</Layout>
